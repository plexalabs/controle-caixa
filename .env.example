# =============================================================================
# .env.example — Variáveis de ambiente do Sistema de Controle de Caixa
# =============================================================================
#
# Este arquivo serve como template/documentação. NUNCA preencha valores reais
# aqui. Para uso local:
#   1. Copie este arquivo para `.env` (já bloqueado pelo .gitignore).
#   2. Preencha apenas as variáveis que o seu papel precisa.
#   3. Nunca cometa o `.env` resultante.
#
# Documentação canônica: docs/03_BACKEND_SUPABASE_DATABASE.md §3.
#
# Convenção de papéis:
#   [PUBLIC]   — pode ser exposto no cliente (Excel, Web).
#   [SECRET]   — só backend (Edge Functions, scripts admin).
#   [VAULT]    — armazenado em vault corporativo, nunca em arquivo solto.
# =============================================================================


# --- Supabase --------------------------------------------------------------
# [PUBLIC] URL do projeto. Visível no cliente.
SUPABASE_URL=https://<project-ref>.supabase.co

# [PUBLIC] Chave anônima JWT. Permite operações que passam por RLS.
SUPABASE_ANON_KEY=

# [SECRET] [VAULT] Chave service_role. BYPASSA RLS — usar apenas em Edge
# Functions e scripts administrativos. NUNCA no Excel ou Web.
SUPABASE_SERVICE_ROLE_KEY=

# [VAULT] Senha do banco Postgres. Necessária só para conexão direta via
# psql/pgAdmin. O MCP usa OAuth, não precisa dessa senha.
SUPABASE_DB_PASSWORD=


# --- Google OAuth (Auth provider) ------------------------------------------
# [SECRET] Cadastrados em Supabase Auth → Providers → Google.
# Criados em console.cloud.google.com (ver docs/SETUP_GOOGLE_OAUTH.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [PUBLIC] Domínio único aceito no login. Hardcoded no banco também (config).
AUTH_DOMINIO_PERMITIDO=vdboti.com.br


# --- SMTP (Edge Function de notificação por email) -------------------------
# [SECRET]
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=


# --- Criptografia de PII ---------------------------------------------------
# [SECRET] [VAULT] AES-256-GCM. Nunca rotacionar sem migração.
MASTER_ENCRYPTION_KEY=


# --- Cloudflare (deploy via MCP, normalmente não em .env) ------------------
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=


# --- Domínios e URLs (referência) ------------------------------------------
# Usados em Site URL / Redirect URLs do Supabase Auth.
WEB_URL_DEV=https://controle-caixa.pages.dev
WEB_URL_PROD=https://caixaboti.plexalabs.com
WEB_URL_LOCAL=http://localhost:8080
