# Cabeçalhos servidos pelo Cloudflare Pages para o build estático
# (caixa-boti.plexalabs.com). CSP estrita por padrão, com exceções
# explicitas pra Supabase (REST + WebSocket), Sentry (ingest beacon)
# e Cloudflare Insights (script + beacon).
#
# O hash sha256 do script-src cobre o snippet inline que o Pages
# injeta automaticamente para Web Analytics; mesmo com Analytics
# desabilitado no Dashboard, mantemos o hash + domínio como fallback
# pra evitar tela em branco se alguém reativar sem coordenar.
#
# Em dev local (npm run dev), os mesmos headers podem ser aplicados
# via vite.config.js para validar antes do build.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-VY2U1GTJm5dVbF6ZC0w0a1xAXWCy9dqDJB+VSyBud8E=' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://shjtwrojdgotmxdbpbta.supabase.co wss://shjtwrojdgotmxdbpbta.supabase.co https://cloudflareinsights.com https://*.ingest.sentry.io https://o4511051433115648.ingest.us.sentry.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
